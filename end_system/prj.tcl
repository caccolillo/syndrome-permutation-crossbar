##############################################################################
# create_aurora_zcu111.tcl
#
# Vivado project creation script for:
#   - ZCU111 (XCZU28DR-2FFVG1517E)
#   - 1-lane Aurora 64B/66B @ 25.78125 Gbps
#   - SFP28 port 0 via GTY Bank 128, Channel 0
#   - USER_MGT_SI570 refclk @ 161.1328125 MHz (V31/V32)
#   - 64-bit AXI4-Stream output for received data
#
# Usage:
#   vivado -mode batch -source create_aurora_zcu111.tcl
#   -- or open Vivado Tcl Console and: source create_aurora_zcu111.tcl
#
# Vivado version tested: 2022.2+
##############################################################################

#--------------------------------------------------------------------
# 1. Project / part setup
#--------------------------------------------------------------------
set proj_name  "zcu111_aurora_sfp28"
set proj_dir   "./vivado_proj"
set part_name  "xczu28dr-ffvg1517-2-e"

create_project ${proj_name} ${proj_dir} -part ${part_name} -force
set_property board_part xilinx.com:zcu111:part0:1.2 [current_project]

#--------------------------------------------------------------------
# 2. Create block design
#--------------------------------------------------------------------
create_bd_design "aurora_bd"
update_compile_order -fileset sources_1

#--------------------------------------------------------------------
# 3. Instantiate Aurora 64B/66B IP
#
#   Key parameters:
#     C_AURORA_LANES     = 1
#     C_LINE_RATE        = 25.78125   (Gbps — SFP28 25G)
#     C_REFCLK_FREQUENCY = 161.1328125 (MHz — USER_MGT_SI570 default
#                          must be reprogrammed via I2C from 156.25 MHz
#                          default; see note below)
#     C_INIT_CLK         = 100        (MHz — from fabric/PS)
#     interface_mode     = Streaming  (AXI4-Stream)
#     flow_mode          = None       (change to UFC/NFC if needed)
#     drp_mode           = Native
#     SupportLevel       = 1          (include GT + example gating)
#     gt_type            = GTY        (XCZU28DR has GTY, not GTH)
#
#   NOTE on refclk frequency:
#     The USER_MGT_SI570 (U49) powers up at 156.250 MHz by default.
#     For 25.78125 Gbps you need 161.1328125 MHz (25781.25 / 160).
#     Program U49 via I2C1 from the PS before releasing aurora reset,
#     or use the Xilinx si570 driver / BSP example.
#     Alternatively run 156.250 MHz → line rate = 24.9800 Gbps
#     (still >20.48 Gbps required, but use C_LINE_RATE=24.98 in that
#     case and update the refclk parameter accordingly).
#--------------------------------------------------------------------
create_ip -name aurora_64b66b \
          -vendor xilinx.com \
          -library ip \
          -version 12.0 \
          -module_name aurora_64b66b_0

set_property -dict [list \
  CONFIG.C_AURORA_LANES          {1}              \
  CONFIG.C_LINE_RATE             {25.78125}       \
  CONFIG.C_REFCLK_FREQUENCY      {161.1328125}    \
  CONFIG.C_INIT_CLK              {100}            \
  CONFIG.interface_mode          {Streaming}      \
  CONFIG.flow_mode               {None}           \
  CONFIG.drp_mode                {Native}         \
  CONFIG.SupportLevel            {1}              \
  CONFIG.C_GT_LOC_1              {X0Y0}           \
] [get_ips aurora_64b66b_0]

generate_target all [get_ips aurora_64b66b_0]

#--------------------------------------------------------------------
# 4. Add IP to block design as RTL reference (non-BD flow)
#    We wire aurora outside the BD for full XDC control.
#    Alternatively, right-click the IP in IP Catalog inside the BD.
#--------------------------------------------------------------------
# (If you prefer a pure BD flow, use:
#   add_modules_to_bd aurora_64b66b_0
# and connect AXI-Stream ports to a FIFO / DMA.)

#--------------------------------------------------------------------
# 5. Create a top-level RTL wrapper
#--------------------------------------------------------------------
set top_file "${proj_dir}/${proj_name}.srcs/sources_1/new/aurora_top.v"
file mkdir [file dirname $top_file]

set fp [open $top_file w]
puts $fp {
// aurora_top.v  –  ZCU111 Aurora 64B/66B top-level wrapper
// Auto-generated by create_aurora_zcu111.tcl
// ------------------------------------------------------------
// Port list exposes:
//   - GTY serial I/O (connect to SFP28 port 0 via XDC)
//   - USER_MGT_SI570 refclk differential input
//   - init_clk  (100 MHz from PS or fabric BUFG)
//   - AXI4-Stream 64-bit receive bus (m_axis_rx_*)
//   - AXI4-Stream 64-bit transmit bus (s_axis_tx_*)
//   - Status / control signals

`timescale 1ns/1ps

module aurora_top (
    // GTY serial — connect to SFP28 J0 (Bank 128, Ch0)
    input  wire         sfp0_rx_p,          // MGTYRXP0_128  / AA45
    input  wire         sfp0_rx_n,          // MGTYRXN0_128  / AA46
    output wire         sfp0_tx_p,          // MGTYTXP0_128  / Y42
    output wire         sfp0_tx_n,          // MGTYTXN0_128  / Y43

    // GTY reference clock — USER_MGT_SI570 (161.1328125 MHz)
    input  wire         mgt_refclk_p,       // MGTREFCLK0P_128 / V31
    input  wire         mgt_refclk_n,       // MGTREFCLK0N_128 / V32

    // Fabric init clock (100 MHz, e.g. from PS or MMCM)
    input  wire         init_clk,

    // Synchronous reset (active high, hold ≥128 init_clk cycles)
    input  wire         reset,

    // ---- AXI4-Stream RX (received data out to user logic) --------
    output wire [63:0]  m_axis_rx_tdata,
    output wire [7:0]   m_axis_rx_tkeep,
    output wire         m_axis_rx_tvalid,
    output wire         m_axis_rx_tlast,
    input  wire         m_axis_rx_tready,

    // ---- AXI4-Stream TX (user data in) ---------------------------
    input  wire [63:0]  s_axis_tx_tdata,
    input  wire [7:0]   s_axis_tx_tkeep,
    input  wire         s_axis_tx_tvalid,
    input  wire         s_axis_tx_tlast,
    output wire         s_axis_tx_tready,

    // ---- Recovered user clock (391 MHz nominal for 25.78 Gbps) ---
    output wire         user_clk_out,

    // ---- Status --------------------------------------------------
    output wire         channel_up,
    output wire         lane_up,
    output wire         hard_err,
    output wire         soft_err,
    output wire         frame_err,
    output wire         tx_lock
);

    //----------------------------------------------------------------
    // Internal wires
    //----------------------------------------------------------------
    wire gt_refclk;             // from IBUFDS_GTE4
    wire gt_refclk_out;         // refclk monitor output (unused)
    wire sys_reset_out;         // aurora internal reset
    wire pll_not_locked;
    wire tx_resetdone;
    wire rx_resetdone;

    //----------------------------------------------------------------
    // Differential refclk buffer  (mandatory for GTY refclk pins)
    //----------------------------------------------------------------
    IBUFDS_GTE4 #(
        .REFCLK_EN_TX_PATH (1'b0),
        .REFCLK_HROW_CK_SEL(2'b00),
        .REFCLK_ICNTL_RX   (2'b00)
    ) u_ibufds_gte4 (
        .I    (mgt_refclk_p),
        .IB   (mgt_refclk_n),
        .CEB  (1'b0),
        .O    (gt_refclk),
        .ODIV2(gt_refclk_out)
    );

    //----------------------------------------------------------------
    // Aurora 64B/66B core instance
    // Port names follow Xilinx PG074 (aurora_64b66b v12.x)
    //----------------------------------------------------------------
    aurora_64b66b_0 u_aurora (
        // GT Serial
        .rxp                (sfp0_rx_p),
        .rxn                (sfp0_rx_n),
        .txp                (sfp0_tx_p),
        .txn                (sfp0_tx_n),

        // Reference clock
        .gt_refclk1_p       (mgt_refclk_p),   // driven from IBUFDS internally
        .gt_refclk1_n       (mgt_refclk_n),   // when SupportLevel=1

        // Init / reset
        .init_clk           (init_clk),
        .reset_pb           (reset),
        .pma_init           (1'b0),

        // AXI-Stream TX
        .s_axi_tx_tdata     (s_axis_tx_tdata),
        .s_axi_tx_tvalid    (s_axis_tx_tvalid),
        .s_axi_tx_tready    (s_axis_tx_tready),

        // AXI-Stream RX
        .m_axi_rx_tdata     (m_axis_rx_tdata),
        .m_axi_rx_tvalid    (m_axis_rx_tvalid),

        // Clocks out
        .user_clk_out       (user_clk_out),
        .sync_clk_out       (),             // tie off if unused

        // Status
        .channel_up         (channel_up),
        .lane_up            (lane_up),
        .hard_err           (hard_err),
        .soft_err           (soft_err),

        // Loopback (000 = normal operation)
        .loopback           (3'd0),

        // Power down
        .power_down         (1'b0),

        // GT common (tied for single-quad use — adjust if sharing quad)
        .sys_reset_out      (sys_reset_out)
    );

    // m_axis_rx_tready: Aurora RX streaming has no backpressure port;
    // wire to 1 or connect a FIFO that asserts ready.
    // The port is exposed on the top for downstream logic.

endmodule
}
close $fp

add_files -norecurse $top_file
update_compile_order -fileset sources_1

#--------------------------------------------------------------------
# 6. Add XDC constraint file
#--------------------------------------------------------------------
set xdc_file "${proj_dir}/${proj_name}.srcs/constrs_1/new/aurora_zcu111.xdc"
file mkdir [file dirname $xdc_file]

# XDC is created separately — see aurora_zcu111.xdc
add_files -fileset constrs_1 -norecurse \
    [file normalize "./aurora_zcu111.xdc"]
add_files -fileset constrs_1 -norecurse ./constraints.xdc
set_property top aurora_bd_wrapper [current_fileset]

#--------------------------------------------------------------------
# 7. Set up IP repo folder
#--------------------------------------------------------------------
set_property  ip_repo_paths  ../ [current_project]
update_ip_catalog

#--------------------------------------------------------------------
# 8. Create block design
#--------------------------------------------------------------------
source ./bd.tcl
make_wrapper -files [get_files ./vivado_proj/zcu111_aurora_sfp28.srcs/sources_1/bd/aurora_bd/aurora_bd.bd] -top
add_files -norecurse ./vivado_proj/zcu111_aurora_sfp28.gen/sources_1/bd/aurora_bd/hdl/aurora_bd_wrapper.v
update_compile_order -fileset sources_1



#--------------------------------------------------------------------
# 9. Synthesis & implementation run settings
#--------------------------------------------------------------------
set_property strategy            "Vivado Synthesis Defaults" \
    [get_runs synth_1]
set_property strategy            "Performance_ExplorePostRoutePhysOpt" \
    [get_runs impl_1]

# Optional: enable incremental compile for faster iteration
# set_property incremental_checkpoint \
#     ${proj_dir}/${proj_name}.runs/impl_1/aurora_top_routed.dcp \
#     [get_runs impl_1]



# Launch synthesis
launch_runs synth_1 -jobs 6
wait_on_run synth_1

# Open synthesized design and save worst 10 timing paths
open_run synth_1
report_timing \
    -max_paths 10 \
    -delay_type max \
    -path_type full_clock \
    -file "$proj_dir/../post_synth_timing_top10.txt"

# Launch implementation
launch_runs impl_1 -to_step route_design
wait_on_run impl_1

# Open implemented design and save worst 10 timing paths
open_run impl_1
report_timing_summary -file timing_summary.rpt "$proj_dir/../post_impl_timing_top10.txt"



puts ""
puts "==================================================================="
puts " Project created: ${proj_dir}/${proj_name}.xpr"
puts ""
puts " Next steps:"
puts "   1. Program USER_MGT_SI570 (U49) to 161.1328125 MHz via I2C"
puts "      before releasing aurora reset (PS bare-metal or Linux driver)"
puts "   2. Open the project and verify Aurora IP port names match your"
puts "      Vivado version (check PG074 for your release)"
puts "   3. Run Synthesis → Implementation → Generate Bitstream"
puts "==================================================================="
